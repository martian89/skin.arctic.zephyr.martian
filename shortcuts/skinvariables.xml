    <variable name="GlobalFanart_MultiWidgets_NoFocus" containers="1...25" parent="Integer.IsEqual(Container(300).ListItem.Property(id),{id})">
        <!-- Widget 1 -->
        <value condition="Control.IsVisible({id}3101) + !String.IsEmpty(Container({id}3101).ListItem.Art(fanart))">$INFO[Container({id}3101).ListItem.Art(fanart)]</value>
        <value condition="Control.IsVisible({id}3101) + !String.IsEmpty(Container({id}3101).ListItem.Property(fanart))">$INFO[Container({id}3101).ListItem.Property(fanart)]</value>
        <!-- PVR -->
        <value condition="Control.IsVisible({id}3101) + String.StartsWith(Container({id}3101).ListItem.FolderPath,pvr://) + !String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.Fanart))">$INFO[Window(Home).Property(TMDbHelper.ListItem.Fanart)]</value>
        <!-- Weather -->
        <value condition="Control.IsVisible({id}3101) + !String.IsEmpty(Container({id}3101).ListItem.Property(FanartCode)) + $EXP[HasWeatherFanartMulti]">$VAR[WeatherFanartPath]$INFO[Container({id}3101).ListItem.Property(FanartCode)]/</value>
        <value condition="Control.IsVisible({id}3101) + !String.IsEmpty(Container({id}3101).ListItem.Property(FanartCode)) + $EXP[HasWeatherFanartSingle]">$VAR[WeatherFanartPath]$INFO[Container({id}3101).ListItem.Property(FanartCode),,.jpg]</value>
        <!-- Fallback -->
        <value condition="Control.IsVisible({id}3101) + [String.IsEqual(Container({id}3101).ListItem.DBType,movie) | String.IsEqual(Container({id}3101).ListItem.DBType,set)]">special://skin/extras/backgrounds/fallbacks/film.jpg</value>
        <value condition="Control.IsVisible({id}3101) + [String.IsEqual(Container({id}3101).ListItem.DBType,artist) | String.IsEqual(Container({id}3101).ListItem.DBType,album) | String.IsEqual(Container({id}3101).ListItem.DBType,song) | String.IsEqual(Container({id}3101).ListItem.DBType,musicvideo)]">special://skin/extras/backgrounds/fallbacks/music.jpg</value>
        <value condition="Control.IsVisible({id}3101) + [String.IsEqual(Container({id}3101).ListItem.DBType,tvshow) | String.IsEqual(Container({id}3101).ListItem.DBType,season) | String.IsEqual(Container({id}3101).ListItem.DBType,episode) | String.IsEqual(Container({id}3101).ListItem.DBType,video)]">special://skin/extras/backgrounds/fallbacks/tv.jpg</value>
        <value condition="Control.IsVisible({id}3101) + Integer.IsGreater(Container({id}3101).NumItems,0)">$VAR[GlobalFanart_Fallback]</value>

