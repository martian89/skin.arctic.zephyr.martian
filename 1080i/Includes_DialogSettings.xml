	<include name="DialogMusicSettingsContent">
		<control type="radiobutton" id="101">
			<include>DefContextButtonGradient</include>
			<align>left</align>
			<label>31026</label>
			<disabledcolor>$VAR[OSDPanelWhite12]</disabledcolor>
			<selected>Skin.HasSetting(musicosd.showvideolyrics)</selected>
			<onclick>Skin.ToggleSetting(musicosd.showvideolyrics)</onclick>
			<visible>System.AddonIsEnabled(script.cu.lrclyrics)</visible>
		</control>
		<control type="radiobutton" id="102">
			<include>DefContextButtonGradient</include>
			<align>left</align>
			<label>31559</label>
			<selected>Skin.HasSetting(EnableMusicScrollingText)</selected>
			<onclick>Skin.ToggleSetting(EnableMusicScrollingText)</onclick>
		</control>
		<control type="radiobutton" id="103" description="Show Fanart">
			<align>left</align>
			<include>DefContextButtonGradient</include>
			<label>20445</label>
			<selected>$EXP[Visualisation_ShowFanart]</selected>
			<onclick>Skin.ToggleSetting(musicosd.hidefanart)</onclick>
		</control>
		<control type="button" id="104" description="Fallback Fanart">
			<include>DefContextButtonGradient</include>
			<align>left</align>
			<label>$LOCALIZE[31567]:</label>
			<label2>$VAR[LabelFallbackImage]</label2>
			<include content="Def_SelectImage_Actions">
				<param name="header" value="$LOCALIZE[31150]" />
				<param name="property" value="fanart.fallback.music" />
			</include>
			<enable>$EXP[Visualisation_ShowFanart]</enable>
		</control>
		<control type="radiobutton" id="105" description="Show slideshow in background">
			<align>left</align>
			<include>DefContextButtonGradient</include>
			<label>31561</label>
			<selected>$EXP[Visualisation_ShowSlideshow]</selected>
			<onclick condition="!System.HasAddon(script.artistslideshow)">InstallAddon(script.artistslideshow)</onclick>
			<onclick condition="System.HasAddon(script.artistslideshow) + !System.AddonIsEnabled(script.artistslideshow)">EnableAddon(script.artistslideshow)</onclick>
			<onclick condition="System.AddonIsEnabled(script.artistslideshow) + Skin.HasSetting(ArtistSlideShow.Disabled)">Skin.Reset(ArtistSlideShow.Disabled)</onclick>
			<onclick condition="System.AddonIsEnabled(script.artistslideshow) + !Skin.HasSetting(ArtistSlideShow.Disabled)">Skin.SetBool(ArtistSlideShow.Disabled)</onclick>
			<enable>$EXP[Visualisation_ShowFanart]</enable>
		</control>
		<control type="radiobutton" id="106" description="Animate Artist slideshow">
			<align>left</align>
			<include>DefContextButtonGradient</include>
			<label>31354</label>
			<selected>$EXP[Visualisation_AnimateFanart]</selected>
			<onclick>Skin.ToggleSetting(ArtistSlideshow.Animate)</onclick>
			<enable>$EXP[Visualisation_ShowFanart]</enable>
		</control>
		<control type="button" id="107">
			<description>Visualisation</description>
			<include>DefContextButtonGradient</include>
			<label>$LOCALIZE[250]:</label>
			<label2 fallback="424">$VAR[LabelVisualisation]</label2>
			<align>left</align>
			<onclick>SendClick(500)</onclick>
		</control>
		<control type="button" id="108">
			<description>Visualisation</description>
			<include>DefContextButtonGradient</include>
			<align>left</align>
			<label>$LOCALIZE[31978]:</label>
			<label2>$VAR[LabelVisualisationPresent]</label2>
			<onclick>ActivateWindow(visualisationpresetlist)</onclick>
			<visible>Visualisation.HasPresets</visible>
		</control>
		<control type="button" id="109">
			<description>Visualisation</description>
			<include>DefContextButtonGradient</include>
			<label>$LOCALIZE[31977]</label>
			<align>left</align>
			<onclick>Addon.Default.OpenSettings(xbmc.player.musicviz)</onclick>
			<enable>Visualisation.Enabled</enable>
		</control>
	</include>

