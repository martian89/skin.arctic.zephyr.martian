	<menu name="powermenu">
		<allow widgets="false" backgrounds="false" submenus="false" />
        <defaults>
            <action when="before" condition="Window.IsActive(DialogButtonMenu.xml)">Close</action>
        </defaults>
		<item name="reload skin">
			<label2>Power Menu Shortcut</label2>
			<label>31195</label>
			<icon>special://skin/extras/icons/power.png</icon>
			<action>ReloadSkin()</action>
		</item>
		<item name="logoff">
			<label2>Power Menu Shortcut</label2>
			<label>31360</label>
	        <action>Dialog.Close(all,true)</action>
			<action>SystemLogOff</action>
			<icon>special://skin/extras/icons/power.png</icon>
			<visible>[System.HasLoginScreen | Integer.IsGreater(System.ProfileCount,1)] + System.Loggedon</visible>
		</item>
		<item name="mastermode">
			<label2>Power Menu Shortcut</label2>
			<label>20046</label>
			<icon>special://skin/extras/icons/power.png</icon>
			<action>mastermode</action>
			<visible>System.HasLocks</visible>
		</item>
		<item name="exit">
			<label2>Power Menu Shortcut</label2>
			<label>13012</label>
			<icon>special://skin/extras/icons/power.png</icon>
			<action>Quit()</action>
			<visible>System.ShowExitButton</visible>
		</item>
		<item name="powerdown">
			<label2>Power Menu Shortcut</label2>
			<label>13005</label>
			<icon>special://skin/extras/icons/power.png</icon>
			<action>Powerdown()</action>
			<visible>System.CanPowerDown</visible>
		</item>
		<item name="shutdowntimer">
			<label2>Power Menu Shortcut</label2>
			<label>20150</label>
			<icon>special://skin/extras/icons/power.png</icon>
			<action>AlarmClock(shutdowntimer,Shutdown())</action>
			<visible>!System.HasAlarm(shutdowntimer)</visible>
			<visible>System.CanPowerDown | System.CanSuspend | System.CanHibernate</visible>
		</item>
		<item name="cancel timer">
			<label2>Power Menu Shortcut</label2>
			<label>20151</label>
			<icon>special://skin/extras/icons/power.png</icon>
			<action>CancelAlarm(shutdowntimer)</action>
			<visible>System.HasAlarm(shutdowntimer)</visible>
		</item>
		<item name="suspend">
			<label2>Power Menu Shortcut</label2>
			<label>13011</label>
			<icon>special://skin/extras/icons/power.png</icon>
			<action>Suspend()</action>
			<visible>System.CanSuspend</visible>
		</item>
		<item name="hibernate">
			<label2>Power Menu Shortcut</label2>
			<label>13010</label>
			<icon>special://skin/extras/icons/power.png</icon>
			<action>Hibernate()</action>
			<visible>System.CanHibernate</visible>
		</item>
		<item name="reboot">
			<label2>Power Menu Shortcut</label2>
			<label>13013</label>
			<icon>special://skin/extras/icons/power.png</icon>
			<action>Reset()</action>
			<visible>System.CanReboot</visible>
		</item>
		<item name="reboot to android">
			<label2>Power Menu Shortcut</label2>
			<label>31232</label>
			<icon>special://skin/extras/icons/power.png</icon>
	        <action>System.ExecWait("/usr/sbin/rebootfromnand")</action>
	        <action>Reset()</action>
			<visible>System.PathExist("/dev/env")</visible>
		</item>
		<item name="settings">
			<label>5</label>
			<icon>special://skin/extras/icons/settings.png</icon>
			<label2>Power Menu Shortcut</label2>
			<action>ActivateWindow(settings)</action>
			<visible>System.Loggedon</visible>
		</item>
	</menu>

