<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">100</defaultcontrol>
    <controls>
        <include content="DefDialog">
            <param name="header_id" value="2"/>
            <param name="width" value="1700"/>

            <!-- Start of dialog specific (nested) content -->
            <control type="group">
                <top>115</top>
                <left>40</left>
                <control type="image">
                    <width>301</width>
                    <description>Large Icon Image</description>
                    <texture fallback="DefaultAddonNone.png">$VAR[Image_VideoManager_Poster]</texture>
                    <aspectratio align="center" aligny="top">keep</aspectratio>
                </control>
                <control type="image">
                    <left>337</left>
                    <height>687</height>
                    <width>1</width>
                    <texture colordiffuse="Black12">common/white.png</texture>
                </control>  
                <control type="label">
                    <visible>Control.HasFocus(50)</visible>
                    <height>50</height>
                    <bottom>30</bottom>
                    <left>0</left>
                    <right>140</right>
                    <font>Tiny</font>
                    <align>left</align>
                    <scroll>true</scroll>
                    <scrollspeed>40</scrollspeed>
                    <textcolor>Black70</textcolor>
                    <label>$VAR[Label_VideoManager_FileNameAndPath]</label>
                    <include>Animation.FadeIn</include>
                    <include>Animation.FadeOut</include>
                </control>    
            </control>
     
            <!-- Standard select dialog content -->
            <control type="group" id="100">
                <top>115</top>              
                <right>376</right>
                <width>946</width>
                <height>690</height>
                <control type="list" id="50">
                    <right>0</right>
                    <width>100%</width>
                    <height>100%</height>
                    <onleft>101</onleft>
                    <onright>1723</onright>
                    <pagecontrol>1723</pagecontrol>
                    <include content="Def_MediaInfoListLayout">
                        <param name="focused" value="Control.HasFocus(50)"/>
                        <param name="width" value="946"/>
                    </include>
                </control>
            </control>                
            
            <include content="DialogSelectCommonLayout">
                <param name="buttons" value="Def_VideoManager_Buttons"/>
            </include>
        </include>
    </controls>
</window>