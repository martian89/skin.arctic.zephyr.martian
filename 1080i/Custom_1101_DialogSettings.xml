<?xml version="1.0" encoding="UTF-8"?>
<!-- Foundation -->
<window type="dialog" id="1101">
    <onunload>ClearProperty(CustomDialogSettingsContent,home)</onunload>
    <zorder>1</zorder>
    <defaultcontrol always="true">9000</defaultcontrol>
    <controls>
        <include content="DialogSettingsLayout" condition="String.IsEqual(Window(home).Property(CustomDialogSettingsContent),videosettings)">
            <param name="content_include" value="DialogVideoSettingsContent"/>
        </include>
        <include content="DialogSettingsLayout" condition="String.IsEqual(Window(home).Property(CustomDialogSettingsContent),musicsettings)">
            <param name="height" value="690"/>
            <param name="content_include" value="DialogMusicSettingsContent"/>
        </include>
        <include content="DialogSettingsLayout" condition="String.IsEqual(Window(home).Property(CustomDialogSettingsContent),gamesettings)">
            <param name="content_include" value="DialogGameSettingsContent"/>
            <param name="width" value="566" />
        </include>
        <include content="DialogSettingsLayout" condition="String.IsEqual(Window(home).Property(CustomDialogSettingsContent),streamsettings)">
            <param name="header_label" value="13392" />
            <param name="top" value="280" />
            <param name="height" value="340" />
            <param name="width" value="816" />
            <param name="content_include" value="DialogStreamSettingsContent"/>
        </include>
    </controls>
</window>
