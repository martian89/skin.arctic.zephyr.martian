        <value condition="Control.IsVisible({id}602) + [String.IsEqual(Container({id}602).ListItem.DBType,artist) | String.IsEqual(Container({id}602).ListItem.DBType,album) | String.IsEqual(Container({id}602).ListItem.DBType,song) | String.IsEqual(Container({id}602).ListItem.DBType,musicvideo)]">special://skin/extras/backgrounds/fallbacks/music.jpg</value>
        <value condition="Control.IsVisible({id}602) + [String.IsEqual(Container({id}602).ListItem.DBType,tvshow) | String.IsEqual(Container({id}602).ListItem.DBType,season) | String.IsEqual(Container({id}602).ListItem.DBType,episode) | String.IsEqual(Container({id}602).ListItem.DBType,video)]">special://skin/extras/backgrounds/fallbacks/tv.jpg</value>
        <value condition="Control.IsVisible({id}602) + Integer.IsGreater(Container({id}602).NumItems,0)">$VAR[GlobalFanart_Fallback]</value>

        <!-- Widget 3 -->
        <value condition="Control.IsVisible({id}603) + !String.IsEmpty(Container({id}603).ListItem.Art(fanart))">$INFO[Container({id}603).ListItem.Art(fanart)]</value>
